# Copy to .env.local for local dev, or paste into Vercel project env vars for prod.

# --- Supabase ---
# From Supabase project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# --- Anthropic ---
# From console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-...

# --- App URL (optional) ---
# Used when generating the copy-link URLs and for OG metadata. If blank,
# the app falls back to the request's host header.
NEXT_PUBLIC_APP_URL=https://your-domain.vercel.app

# --- Stripe (STUBBED for MVP — not used yet) ---
# When wiring up real checkout, set these:
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
